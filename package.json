{
  "name": "react-typescript-template",
  "version": "0.1.0",
  "private": true,
  "keywords": [
    "typescript",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noshiro-pf/react-typescript-template.git"
  },
  "license": "Apache-2.0",
  "author": "noshiro-pf <noshiro.pf@gmail.com>",
  "type": "module",
  "scripts": {
    "build": "tsx ./scripts/cmd/build.mts",
    "build:min": "tsx ./scripts/cmd/build.mts --skip-check",
    "check:ext": "tsx ./scripts/cmd/check-ext.mts",
    "check-all": "tsx ./scripts/cmd/check-all.mts",
    "clean": "pnpm run /clean:.*/",
    "clean:logs": "npx rimraf ./*.log",
    "codemod": "run-s codemod:uncommitted:as-const fmt codemod:uncommitted:readonly fmt",
    "codemod:diff": "run-s codemod:diff:as-const fmt codemod:diff:readonly fmt",
    "codemod:diff:as-const": "append-as-const --diff-from origin/main '{src,scripts}/**/*.{mts,tsx}'",
    "codemod:diff:readonly": "convert-to-readonly --diff-from origin/main '{src,scripts}/**/*.{mts,tsx}'",
    "codemod:full": "run-s codemod:full:as-const fmt codemod:full:readonly fmt",
    "codemod:full:as-const": "append-as-const '{src,scripts}/**/*.{mts,tsx}'",
    "codemod:full:readonly": "convert-to-readonly '{src,scripts}/**/*.{mts,tsx}'",
    "codemod:uncommitted:as-const": "append-as-const --uncommitted '{src,scripts}/**/*.{mts,tsx}'",
    "codemod:uncommitted:readonly": "convert-to-readonly --uncommitted '{src,scripts}/**/*.{mts,tsx}'",
    "cspell": "cspell \"**\" --gitignore --gitignore-root ./ --no-progress",
    "dev": "pnpm run z:vite",
    "fmt": "format-uncommitted",
    "fmt:diff": "format-diff-from origin/main",
    "fmt:full": "prettier --write .",
    "gh:apply-all": "gh-apply-all",
    "gh:apply-repository-settings": "gh-apply-repository-settings",
    "gh:apply-rulesets": "gh-apply-rulesets",
    "gh:apply-variables": "gh-apply-variables",
    "gh:backup-all": "gh-backup-all",
    "gh:backup-repository-settings": "gh-backup-repository-settings",
    "gh:backup-rulesets": "gh-backup-rulesets",
    "gi": "run-s gi:src fmt",
    "gi:src": "gen-index-ts ./src --index-ext .mts --export-ext .mjs --target-ext .mts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "md": "markdownlint-cli2",
    "preview": "vite preview --config ./configs/vite.config.mts",
    "test": "pnpm run z:vitest run",
    "test:cov": "pnpm run z:vitest run --coverage",
    "test:cov:ui": "vite preview --outDir ./coverage",
    "test:ui": "pnpm run z:vitest --ui",
    "testw": "pnpm run z:vitest watch",
    "tsc": "node ./node_modules/typescript-native/bin/tsc --noEmit",
    "tscw": "node ./node_modules/typescript-native/bin/tsc --noEmit --watch -p ./tsconfig.json",
    "type-check": "node ./node_modules/typescript-native/bin/tsc --noEmit",
    "update-packages": "pnpm update --latest",
    "z:vite": "vite --config ./configs/vite.config.mts",
    "z:vitest": "vitest --config ./configs/vitest.config.mts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ts-type-forge": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "cspell": "10.0.1",
    "dedent": "1.7.2",
    "eslint": "9.39.4",
    "eslint-config-typed": "5.3.0",
    "github-settings-as-code": "1.2.9",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "markdownlint": "0.41.0",
    "markdownlint-cli2": "0.23.0",
    "npm-run-all2": "9.0.2",
    "prettier": "3.9.4",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-packagejson": "3.0.2",
    "ts-codemod-lib": "2.2.1",
    "ts-data-forge": "9.0.0",
    "ts-repo-utils": "10.1.2",
    "tslib": "2.8.1",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-native": "npm:typescript@7.0.1-rc",
    "vite": "8.1.4",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "engines": {
    "node": ">=22.22.2",
    "pnpm": ">=9.0.0"
  },
  "volta": {
    "node": "26.3.1"
  }
}
